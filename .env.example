# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase project URL.
VITE_SUPABASE_URL="https://jswaergqcrrgajudvzts.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase anonymous API key.
VITE_SUPABASE_ANON_KEY="sb_publishable_lz-33jMEyQvBhGXKsh3Cfg_wBJ2VTIT"

# SUPABASE_SERVICE_ROLE_KEY: chave server-side para ingestão, sync e read model do WhatsApp.
SUPABASE_SERVICE_ROLE_KEY="sb_service_role_xxxxxxxxxxxxxxxxxxxxxxxxx"

# GREEN_API_BASE_URL: URL base da instância Green API.
GREEN_API_BASE_URL="https://xxxx.api.greenapi.com/waInstancexxxxxxxxxx"

# GREEN_API_TOKEN: token da instância Green API.
GREEN_API_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# GREEN_API_TIMEOUT_MS: timeout das chamadas server-side à Green API.
GREEN_API_TIMEOUT_MS="8000"

# WHATSAPP_DEFAULT_INSTANCE_ID: UUID lógico da instância no Supabase.
WHATSAPP_DEFAULT_INSTANCE_ID="11111111-1111-1111-1111-111111111111"

# WHATSAPP_DEFAULT_INSTANCE_LABEL: rótulo amigável exibido internamente.
WHATSAPP_DEFAULT_INSTANCE_LABEL="WhatsApp Principal"

# WHATSAPP_OWNER_USER_ID: opcional, para associar a instância a um usuário auth do Supabase.
WHATSAPP_OWNER_USER_ID=""

# GREEN_API_WEBHOOK_SECRET: segredo usado no endpoint /api/webhooks/green.
GREEN_API_WEBHOOK_SECRET="troque-por-um-segredo-forte"

# WHATSAPP_SYNC_SECRET: segredo opcional para acionar /api/internal/reconcile manualmente.
WHATSAPP_SYNC_SECRET="troque-por-outro-segredo-forte"
