# Local PostgreSQL database used by the Hostinger VPS deployment.
DATABASE_URL="postgresql://rcmolina:CHANGE_ME@127.0.0.1:5432/rcmolina"

# Local uploaded files storage. In production this should live under /var/www/rc-molina/shared/uploads.
UPLOAD_DIR="./uploads"

# Public application URL used by OAuth callbacks and external links.
APP_URL="https://rcmolinaseguros.resolveplanilhas.com.br"

# Administrative user bootstrap. ADMIN_INITIAL_PASSWORD is only used when the admin e-mail does not exist yet.
ADMIN_EMAIL="admin@rcmolina.com.br"
ADMIN_INITIAL_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
AUTH_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

# E-mail delivery for OTP/login codes.
RESEND_API_KEY="YOUR_RESEND_API_KEY"
RESEND_FROM_EMAIL="RC Molina Seguradora <no-reply@zodiacoprismatico.pt>"

# Gmail Webmail integration.
GMAIL_DATABASE_URL=""
GMAIL_GOOGLE_CLIENT_ID=""
GMAIL_GOOGLE_CLIENT_SECRET=""
GMAIL_GOOGLE_REDIRECT_URI="https://rcmolinaseguros.resolveplanilhas.com.br/api/gmail/callback"
GMAIL_ALLOWED_ACCOUNT="rcmolina.invest.segurosaude@gmail.com"
GMAIL_TOKEN_ENCRYPTION_KEY=""
GMAIL_PUBLIC_BASE_URL="https://rcmolinaseguros.resolveplanilhas.com.br"

# Backward-compatible aliases accepted by the Gmail module.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://rcmolinaseguros.resolveplanilhas.com.br/api/gmail/callback"
ALLOWED_GMAIL_ACCOUNT="rcmolina.invest.segurosaude@gmail.com"
TOKEN_ENCRYPTION_KEY=""
PUBLIC_BASE_URL="https://rcmolinaseguros.resolveplanilhas.com.br"
