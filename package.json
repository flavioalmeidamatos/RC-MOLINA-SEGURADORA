{
  "name": "react-example",
  "private": true,
  "version": "2.6.5",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "dev:e2e": "node --import tsx -e \"process.env.PORT='3100'; import('./server.ts')\"",
    "dev:campanhas": "start http://localhost:3000/campanhas && npm run dev",
    "start": "tsx server.ts",
    "start:prod": "node --import tsx -e \"process.env.NODE_ENV='production'; import('./server.ts')\"",
    "deploy:hostinger": "powershell -ExecutionPolicy Bypass -File scripts/deploy-hostinger.ps1",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@tinymce/tinymce-react": "^6.3.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "emoji-picker-react": "^4.19.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.17.0",
    "tesseract.js": "^7.0.0",
    "tinymce": "^8.5.0",
    "vite": "^6.2.0",
    "whatsapp-web.js": "github:pedroslopez/whatsapp-web.js#main",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
